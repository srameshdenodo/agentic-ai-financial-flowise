# Flowise UI credentials
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=changeme

# Must be a stable 32-char string — used to encrypt stored credentials.
# If you change this after first run, all saved credentials will break.
FLOWISE_SECRETKEY_OVERWRITE=change-me-to-a-32-char-secret-key

# OpenAI — add your key here; configure the credential in Flowise UI too
OPENAI_API_KEY=sk-...

# Denodo MCP server (already running on the host machine)
DENODO_MCP_URL=http://host.docker.internal:8080/verticals/mcp
# base64 of admin:admin — change in production
DENODO_BASIC_AUTH=Basic YWRtaW46YWRtaW4=

# Flowise storage paths (inside the container)
DATABASE_PATH=/root/.flowise
LOG_PATH=/root/.flowise/logs
BLOB_STORAGE_PATH=/root/.flowise/storage
