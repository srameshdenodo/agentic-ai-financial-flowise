        "inputs": {
          "agentModel": "chatOpenAI",
          "agentMessages": [],
          "agentToolsBuiltInOpenAI": [],
          "agentTools": [
            {
              "agentSelectedTool": "customMCP",
              "agentSelectedToolConfig": {
                "mcpServerConfig": "{\"url\":\"http://host.docker.internal:8080/verticals/mcp\",\"headers\":{\"Authorization\":\"Basic YWRtaW46YWRtaW4=\",\"Accept\":\"application/json, text/event-stream\"}}",
                "mcpActions": "[\"denodo_verticals_query_financial_customers\",\"denodo_verticals_query_financial_loans\",\"denodo_verticals_query_financial_underwriting\"]"
              }
            }
          ],
          "agentKnowledgeDocumentStores": [],
          "agentKnowledgeVSEmbeddings": [],
          "agentEnableMemory": true,
          "agentMemoryType": "allMessages",
          "agentUserMessage": "You are the Credit Analyst agent in an autonomous loan decision workflow.\nYour job is to assess the creditworthiness of a specific customer using real-time data from Denodo.\n\n## Your Scope\nYou handle ONLY credit assessment. Do not assess payments, property, or make a final decision.\n\n## Your Task\nExtract the customer_id from the conversation (e.g. 20000), then run these steps:\n\nStep 1 - Call query_financial_customers with:\n  where_clause: \"customer_id\" = CUSTOMER_ID\n\nStep 2 - From the result, note the loan details. Then call query_financial_loans with:\n  where_clause: \"customer_id\" = CUSTOMER_ID\n\nStep 3 - From the loan result, note the loan_id. Then call query_financial_underwriting with:\n  where_clause: \"loan_id\" = LOAN_ID\n\nReplace CUSTOMER_ID and LOAN_ID with the actual values.\nNote: Always wrap column names in double quotes in where_clause (e.g. \"customer_id\" = 20000).\n\n## Credit Score Bands\n800+    -> Excellent\n740-799 -> Good\n670-739 -> Fair\n<670    -> Poor\n\n## Output Format\nEnd your turn with this exact block (all values from tool results only):\n\nCREDIT_ANALYSIS:\n  customer_id:        [value]\n  full_name:          [first_name last_name]\n  credit_score:       [value] ([band])\n  employment_history: [value]\n  financial_history:  [value]\n  loyalty_tier:       [loyalty_classification]\n  income_band:        [income_band]\n  risk_weighting:     [risk_weighting]\n  loan_amount:        [loan_amount]\n  interest_rate:      [interest_rate]\n  credit_verdict:     [STRONG / ACCEPTABLE / WEAK / INSUFFICIENT_DATA]\n\n## Hard Rules\n- Never fabricate data. Every value must come from a tool result.\n- If data is missing, set credit_verdict to INSUFFICIENT_DATA and explain.\n- Temperature is 0.",
          "agentReturnResponseAs": "userMessage",
          "agentStructuredOutput": [],
          "agentUpdateState": [],
          "cache": "",
          "modelName": "gpt-4o",
          "temperature": "0",
          "streaming": true,
          "allowImageUploads": "",
          "reasoning": false,
          "reasoningEffort": "medium",
          "reasoningSummary": "auto",
