            "cache": "",
            "modelName": "gpt-4o-mini",
            "temperature": 0.9,
            "streaming": true,
            "allowImageUploads": "",
            "reasoning": "",
            "reasoningEffort": "",
            "reasoningSummary": "",
            "maxTokens": "",
            "topP": "",
            "frequencyPenalty": "",
            "presencePenalty": "",
            "timeout": "",
            "strictToolCalling": "",
            "stopSequence": "",
            "basepath": "",
            "baseOptions": "",
            "agentModel": "chatOpenAI"
          }
